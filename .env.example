# AI provider options: openai, gemini, fallback
AI_PROVIDER=gemini

# OpenAI settings
OPENAI_API_KEY=your_openai_api_key_here
MODEL_NAME=gpt-4o-mini

# Gemini settings
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-2.5-flash

# CAI-style settings
CAI_LICENSE_OFF=1
CAI_TRACING=true
CAI_MODE=evidence_summary
